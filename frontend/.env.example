# API Configuration
# Uncomment and update the URLs below to match your backend

# Primary API Base URL (used for all APIs if specific ones are not set)
REACT_APP_API_BASE_URL=https://undogmatically-knotlike-evita.ngrok-free.dev

# Optional: Specific API URLs (these override the primary URL)
# REACT_APP_FLIGHT_API_BASE_URL=https://your-flight-api.com
# REACT_APP_BUS_API_BASE_URL=https://your-bus-api.com
# REACT_APP_ADMIN_API_BASE_URL=https://your-admin-api.com
# REACT_APP_DASHBOARD_API_BASE_URL=https://your-dashboard-api.com
# REACT_APP_PLACES_API_URL=https://your-places-api.com

# Development Settings
# Set to "true" to use direct API calls in development (bypass proxy)
REACT_APP_USE_DIRECT_API_IN_DEV=false

# Default User ID (used as fallback when no user is logged in)
REACT_APP_DEFAULT_USER_ID=user_123

# Authentication
# These are typically set by the login process, not manually
# Admin Token: localStorage.setItem("adminToken", "your-token")
# User ID: localStorage.setItem("userId", "user-id")
